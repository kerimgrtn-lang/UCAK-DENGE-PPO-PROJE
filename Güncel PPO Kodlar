# KISIM 3: PPO KONTROL MOTORU ( PPO GÜNCELLEME VE KAYIP MOTORU (PPO CORE ENGINE))
# =====================================================================
class PPOAgent:
    def __init__(self, state_dim, action_dim, lr=0.0001, gamma=0.99, K_epochs=5, eps_clip=0.2):  #learning rate=0..0003 ten 0.0001 düşürdük.
        self.gamma = gamma  #Gelecek önemi          
        self.eps_clip = eps_clip   # PPO Kırpma katsayısı (epsilon = 0.1) #clip değerini =0.2 den 0.1 e düşürdük.  PPO stabilizasyonu için
        self.K_epochs = K_epochs   # Epoch döngü sayısı (Aynı veri üzerinde 5 kez dönülecek) 
        self.buffer = RolloutBuffer() 
        self.policy = ActorCritic(state_dim, action_dim) 
        self.optimizer = optim.Adam(self.policy.parameters(), lr=lr) 
        self.policy_old = ActorCritic(state_dim, action_dim) 
        self.policy_old.load_state_dict(self.policy.state_dict()) 
        self.MseLoss = nn.MSELoss() 

    def select_action(self, state):    #eski policy ile aksiyon al, buffer’a kaydet
        with torch.no_grad():
            action, action_logprob = self.policy_old.act(state)
        self.buffer.states.append(torch.FloatTensor(state))
        self.buffer.actions.append(torch.FloatTensor(action))
        self.buffer.log_probs.append(action_logprob)
        return action

    def update(self): #(En kritik  kısım önemli)
        # Monte Carlo Tabanlı Gelecek Ödül Tahminleri (Returns) Hesabı
        rewards = []
        discounted_reward = 0
        for reward, is_terminal in zip(reversed(self.buffer.rewards), reversed(self.buffer.is_terminals)):
            if is_terminal:
                discounted_reward = 0 
            discounted_reward = reward + (self.gamma * discounted_reward) #return hesabı yapıyoruz.
            rewards.insert(0, discounted_reward)
            
        old_states = torch.squeeze(torch.stack(self.buffer.states, dim=0)).detach()
        old_actions = torch.squeeze(torch.stack(self.buffer.actions, dim=0)).detach()
        old_log_probs = torch.squeeze(torch.stack(self.buffer.log_probs, dim=0)).detach()
        rewards = torch.FloatTensor(rewards).detach()

        # --- AVANTAJ TAHMİNİ (ADVANTAGE ESTIMATION) ---
        with torch.no_grad():
            _, state_values, _ = self.policy.evaluate(old_states, old_actions)
            advantages = rewards - state_values.squeeze()  #Modelin hatasını hesaplama
            advantages = (advantages - advantages.mean()) / (advantages.std() + 1e-7) # Normalizasyon

         # --- EPOCH VE MINI-BATCH OPTİMİZASYON DÖNGÜSÜ ---
        for _ in range(self.K_epochs):
            log_probs, state_values, dist_entropy = self.policy.evaluate(old_states, old_actions)
            state_values = torch.squeeze(state_values)
            
             # r_t(theta) Oranı hesabı
            ratios = torch.exp(log_probs - old_log_probs)  #PPO politika oranı
            
             # --- KIRPILMIŞ AMAÇ FONKSIYONU (CLIPPED SURROGATE OBJECTIVE) ---
            surr1 = ratios * advantages  #CLIPPED LOSS aşırı öğrenmeyi engeller alttaki satırda buraya dahildir.
            surr2 = torch.clamp(ratios, 1.0 - self.eps_clip, 1.0 + self.eps_clip) * advantages
             # --- TOPLAM KAYIP VE ENTROPİ BONUSU INTEGRASYONU ---
            # Kayıp = -Politika_Kaybı + 0.5 * Critic_MSE - 0.01 * Entropi_Bonusu
            loss = -torch.min(surr1, surr2).mean() + 0.5 * self.MseLoss(state_values, rewards) - 0.01 * dist_entropy.mean() #final loss
            
            self.optimizer.zero_grad() 
            loss.backward()            
            self.optimizer.step()      
            
        self.policy_old.load_state_dict(self.policy.state_dict())
        self.buffer.clear()

