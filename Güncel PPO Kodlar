# KISIM 2: VERİ BELLEĞİ VE SİNİR AĞI MİMARİSİ(TRAJECTORY BELLEK VE ACTOR-CRITIC YAPISI)
# =====================================================================
class RolloutBuffer:
    def __init__(self):
         # Ajanın veri topladığı geçmiş Trajectory (Deneyim) havuzunun listeleri kısmı
        self.states = []   # Geçmiş deneyimler
        self.actions = []
        self.log_probs = []
        self.rewards = []
        self.is_terminals = []
    
    def clear(self): #Eğitim sonrası sıfırlar.
        # On-policy gereği eğitim bittiğinde havuz tamamen sıfırlanır.
        del self.states[:]
        del self.actions[:]
        del self.log_probs[:]
        del self.rewards[:]
        del self.is_terminals[:]

class ActorCritic(nn.Module):
    def __init__(self, state_dim, action_dim):
        super(ActorCritic, self).__init__()
        # [ACTOR MİMARİSİ]: Durumu alıp aksiyon olasılık dağılımının ortalamasını üretir.
        #state → action üretir.
        self.actor_layer = nn.Sequential(             
            nn.Linear(state_dim, 64),
            nn.Tanh(),  
            nn.Linear(64, 64),
            nn.Tanh(),
            nn.Linear(64, action_dim),
            nn.Tanh()   # Çıktıyı [-1, 1] arasına kısıtlar.Sonucu [-1,1] sınırına çekiyoruz.
        )
        # Sürekli aksiyon uzayı keşif (exploration) varyans vektörü
        self.action_var = torch.full((action_dim,), 0.25)  
        # [CRITIC MİMARİSİ]: Durumun değerini tahmin eder (V(s))
        #V(s) kritik değer tahmini yapar.
        self.critic_layer = nn.Sequential(  
            nn.Linear(state_dim, 64),
            nn.Tanh(),
            nn.Linear(64, 64),
            nn.Tanh(),
            nn.Linear(64, 1)
        )

    def act(self, state):
        state = torch.FloatTensor(state)
        action_mean = self.actor_layer(state)
        action_std = self.action_var.sqrt()
        dist = Normal(action_mean, action_std)
        action = dist.sample()  # Keşif amaçlı aksiyon örnekleme  rastgele aksiyon (exploration) örneklemek.
        action_logprob = dist.log_prob(action).sum(dim=-1) # Log-olasılık hesabı 
        return action.detach().numpy(), action_logprob.detach()

    def evaluate(self, state, action): #eğitim sırasında:log_prob hesapla entropy (keşif) state value yapıyoruz.
         # Toplu eğitim (Batch) sırasında aksiyonların güncel ağdaki değerlerini ölçer.
        action_mean = self.actor_layer(state)
        action_std = self.action_var.expand_as(action_mean).sqrt()
        dist = Normal(action_mean, action_std)
        action_logprobs = dist.log_prob(action).sum(dim=-1)  #log_prob PPO için gereklidir.
        dist_entropy = dist.entropy().sum(dim=-1)  # Entropi (Keşif gücü)
        state_values = self.critic_layer(state)   # Critic durum değerleri
        return action_logprobs, state_values, dist_entropy

