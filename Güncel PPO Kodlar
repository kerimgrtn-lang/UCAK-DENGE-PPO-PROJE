                       f"Rüzgar Kuvveti: {w:.1f}\n"
                       f"Türbülans Şiddeti: {t:.2f}\n"
                       f"Hava Basıncı Etkisi: {pr:.2f}\n"
                       f"Ağırlık Merk. Kayması: {cg:.3f}")
    
    line_pitch.set_data(time_steps[:i], pitch_history[:i])
    line_yaw.set_data(time_steps[:i], yaw_history[:i])
    line_aoa.set_data(time_steps[:i], aoa_history[:i])
    
    line_thrust.set_data(time_steps[:i], thrust_history[:i])
    line_wind.set_data(time_steps[:i], wind_history[:i])
    
    line_turb.set_data(time_steps[:i], turbulence_history[:i])
    line_press.set_data(time_steps[:i], pressure_history[:i])
    line_cg.set_data(time_steps[:i], cg_history[:i])
    
    return plane_body, line_pitch, line_yaw, line_aoa, line_thrust, line_wind, line_turb, line_press, line_cg

