# KISIM 4: EĞİTİM DÖNGÜSÜ( AJANIN EĞİTİLMESİ (TRAINING LOOP))
# =====================================================================
env = AircraftEnv()
agent = PPOAgent(state_dim=env.state_dim, action_dim=env.action_dim)

max_episodes = 400
update_timestep = 400 # Her 400 fiziksel adımda bir PPO güncellemesi tetiklenir. (Trajectory sınırımız)
timestep = 0

all_episodes_rewards = []
avg_rewards = []

print("Uçak Modeli PPO ile Eğitiliyor... (Lütfen Bekleyiniz)......")
for episode in range(1, max_episodes + 1):
    state = env.reset()
    episode_reward = 0
    done = False
    while not done:
        timestep += 1
        action = agent.select_action(state)  #karar kodu
        state, reward, done = env.step(action)  #Fizik motoru çalışır.
        agent.buffer.rewards.append(reward)
        agent.buffer.is_terminals.append(done)
        episode_reward += reward
        
        if timestep % update_timestep == 0:  #PPO güncelliyoruz.
            agent.update()
            
    all_episodes_rewards.append(episode_reward)
    avg_rewards.append(np.mean(all_episodes_rewards[-20:]))
    
    if episode % 50 == 0:
        print(f"Bölüm: {episode:03d} | Son 20 Bölüm Ödül Ortalaması: {avg_rewards[-1]:7.2f}")
print("Eğitim Tamamlandı! Canlı Animasyon ve Göstergeler Hazırlanıyor...\n")

