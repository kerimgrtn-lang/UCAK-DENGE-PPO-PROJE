# KISIM 1: UÇAK KONTROL ÇEVRESİ (AIRCRAFT ENVIRONMENT)
# =====================================================================
# Durum (State) Vektörü (8 Boyut): [pitch, yaw, aoa, wind, pressure, turbulence, cg_shift, motor_thrust]
# Aksiyon (Action) Vektörü (3 Boyut): [Pitch Komutu, Yaw Komutu, AoA Kontrol Komutu]
class AircraftEnv:   # Uçağımızın simülasyon ortamı
    def __init__(self):
        self.state_dim = 8       # Durum vektörünün boyutumuz.(8 değişken)
        self.action_dim = 3      # Aksiyon vektörünün boyutu (3 kontrolcümüz.)
        self.dt = 0.02           # Fizik motorunun Zaman adımı (Her adım 0.02 saniye =20ms dir.)
        self.max_steps = 200      # Bir uçuş denemesinin (epizot) maksimum adım sınırı yani max 200 adımdır.
        self.reset()
        
    def reset(self):  # İlk durumu başlatıyoruz.
        self.current_step = 0   #Adım sayacı sıfırlıyoruz.
        # Animasyonda düzelme hareketinin net görülmesi için başlangıçta daha sert bir dengesizlik veriyoruz (+/- 25 derece)
        self.pitch = np.random.uniform(-25.0, 25.0)  #Yunuslama (ileri-geri eğim(yukarı-aşağı eğim))
        self.yaw = np.random.uniform(-20.0, 20.0)  #Sağa-sola sapma
        self.aoa = np.random.uniform(-15.0, 15.0) #Hücum açısı
         
        # Dış bozucu etmenlerin başlangıç değerleri çevresel etkiler.
        self.wind_effect = np.random.uniform(-8.0, 8.0)  #Rüzgar
        self.pressure_effect = np.random.uniform(0.8, 1.2) # Basınç
        self.turbulence = 0.0  #Türbülans başlangıçta yoktur.
        self.cg_shift = np.random.uniform(-0.05, 0.05) # Ağırlık merkezi kayması
        self.motor_thrust = 70.0   #Motor gücümüz (%)
        
        return self._get_state()  #Geri döndürme yapıyoruz.
        
    def _get_state(self):
        return np.array([self.pitch, self.yaw, self.aoa,   #Tüm verileri tek vektör haline getiriyoruz.
                         self.wind_effect, self.pressure_effect, 
                         self.turbulence, self.cg_shift, self.motor_thrust], dtype=np.float32)
                         
    def step(self, action):  #Aksiyon ölçekleme(en kritik yerlerden biri)
        self.current_step += 1  # Model [-1,1] üretir. → Gerçek dereceye çeviriyoruz.
       
        # Ajanın [-1, 1] arası ürettiği aksiyonlar, uçağın fiziksel açı değiştirme sınırlarına (~12 derece) ölçekliyoruz.Aksiyon ölçekliyoruz.
        action_pitch = action[0] * 12.0  
        action_yaw = action[1] * 12.0
        action_aoa = action[2] * 10.0   
        
        # Rüzgarın zamansal değişimi (Random Walk) ve %30 olasılıkla anlık şiddetli türbülans darbesi kısmımız.
        self.wind_effect += np.random.normal(0, 0.3)   #rüzgar etkisini 0.6 dam 0.3 düşürdük  
        self.turbulence = np.random.normal(0, 2.5) if np.random.rand() > 0.7 else 0.0   #%30 ihtimalle türbülans etkisi

         # Motor Bozulması
        thrust_anomaly = np.random.normal(0, 1.5) + (self.turbulence * -0.5)  #Motor oynar + türbülans etkiler
        self.motor_thrust = 70.0 + thrust_anomaly 
        
        # Fiziksel Diferansiyel Denklemler: Aksiyonlar sistemi düzeltir, bozucular saptırır.
        thrust_pitch_effect = (self.motor_thrust - 70.0) * 0.3
        pitch_dot = action_pitch + self.wind_effect * 0.2 + self.turbulence * 0.4 + self.cg_shift * 5.0 + thrust_pitch_effect
        yaw_dot = action_yaw + self.wind_effect * 0.3 + self.turbulence * 0.2
        aoa_dot = action_aoa + (pitch_dot * 0.1) + self.turbulence * 0.2 
         
        # Euler entegrasyonu ile yeni durumlar (Açı = Eski Açı + Hız * Zaman)
        self.pitch += pitch_dot * self.dt  #Pitch değişim hızı (içinde aksiyon,rüzgar,türbülans,yerçekim kayması,motor gücü etkisi var.)
        self.yaw += yaw_dot * self.dt    #Yaw değişim hızı (içinde aksiyon,rüzgar,türbülans,yerçekim kayması,motor gücü etkisi var.)
        self.aoa += aoa_dot * self.dt    #Hücum açısı değişim hızı(içinde aksiyon,rüzgar,türbülans,yerçekim kayması,motor gücü etkisi var.)

         # --- ÖDÜL VE CEZA MİMARİSİ (REWARD DESIGN) ---
        reward = 0.0
        reward -= 0.1 * (self.pitch ** 2)   # Denge noktasından (0) uzaklaştıkça karesel ceza    
        reward -= 0.20 * (self.yaw ** 2)     # Denge noktasından (0) uzaklaştıkça karesel ceza  # katsayıyı 0.1 den 0.2 ye çektik. 
        reward -= 0.15 * (self.aoa ** 2)     
        reward -= 0.01 * np.sum(action ** 2)   # Kontrol yüzeylerinin aşırı titremesini engelleme cezası(gereksiz hareket cezası)

        # Kararlılık ödül bonusu (Açılar +/- 1 derecenin altındaysa ek puan veriyoruz.)
        if abs(self.pitch) < 1.0 and abs(self.yaw) < 1.0 and abs(self.aoa) < 1.0:   
            reward += 15.0  #stabil ise bonus 
            
         # --- İSTERLERİN TOLERANS KONTROLLERİ VE KIRIM DURUMU ---
        done = False  #Çarpışma durumu
        if abs(self.pitch) > 50.0 or abs(self.yaw) > 30.0 or self.aoa < -15.0 or self.aoa > 15.0:  #Uçak kontrolden çıkarsa
            done = True
            reward = -100.0  # Ağır kırım/başarısızlık cezası

            
        if self.current_step >= self.max_steps:
            done = True
            
        return self._get_state(), reward, done

